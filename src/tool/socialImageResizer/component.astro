  zoomIn:     `<svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 0 0 9.5 3 6.5 6.5 0 0 0 3 9.5 6.5 6.5 0 0 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14zM10 9H9v2H7v1h2v2h1v-2h2V11h-2V9z"/></svg>`,
  refresh:    `<svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17.65 6.35A7.958 7.958 0 0 0 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0 1 12 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>`,
  download:   `<svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M5 20h14v-2H5m14-9h-4V3H9v6H5l7 7 7-7z"/></svg>`,
};
---

<div class="sri-container">
  <aside class="sri-sidebar">
    <div class="sri-sidebar-section">
      <h3 class="sri-sidebar-title">
        <span set:html={icons.responsive} />
        {t.sidebarTitle}
      </h3>
      <div class="sri-preset-grid">
        {presets.map((p, index) => (
          <button
            class={`sri-preset-btn${index === 0 ? ' active' : ''}`}
            data-preset={JSON.stringify({ id: p.id, name: p.name, width: p.width, height: p.height, platform: p.iconKey })}
            id={`sri-btn-${p.id}`}
          >
            <div class="sri-preset-icon">
              <span set:html={icons[p.iconKey]} />
            </div>
            <div class="sri-preset-info">
              <span class="sri-preset-name">{p.name}</span>
              <span class="sri-preset-size">{p.size}</span>
            </div>
          </button>
        ))}
      </div>
    </div>
  </aside>

  <main class="sri-main">
    <div class="sri-upload-zone" id="sri-dropzone">
      <div class="sri-upload-icon">
        <span set:html={icons.upload} />
      </div>
      <div class="sri-upload-text">
        <h2>{t.uploadTitle}</h2>
        <p>{t.uploadSubtitle}</p>
      </div>
      <input type="file" id="sri-file-input" accept="image/*" hidden />
    </div>

    <div class="sri-editor-view" id="sri-editor-view">
      <div class="sri-canvas-container" id="sri-canvas-container">
        <canvas id="sri-canvas"></canvas>
      </div>

      <div class="sri-editor-actions">
        <div class="sri-zoom-control">
          <span set:html={icons.zoomOut} />
          <input type="range" id="sri-zoom-range" min="10" max="300" value="100" />
          <span set:html={icons.zoomIn} />
        </div>

        <div class="sri-btn-group">
          <button class="sri-action-btn" id="sri-reset-btn">
            <span set:html={icons.refresh} />
            {t.btnReset}
          </button>
          <button class="sri-action-btn sri-primary" id="sri-download-btn">
            <span set:html={icons.download} />
            {t.btnDownload}
          </button>
        </div>
      </div>
    </div>
  </main>
</div>

<script>
  import { SocialResizer } from './logic';

  let resizer: SocialResizer | null = null;
  let dropzoneEl: HTMLElement | null = null;
  let editorViewEl: HTMLElement | null = null;

  async function handleFile(file: File) {
    if (!file.type.startsWith('image/') || !resizer || !dropzoneEl) return;
    await resizer.loadImage(file);
    dropzoneEl.style.display = 'none';
    editorViewEl?.classList.add('active');
  }

  function setupDropzone(dropzone: HTMLElement, fileInput: HTMLInputElement) {
    dropzone.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', async (e: Event) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (file) await handleFile(file);
    });
    dropzone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropzone.classList.add('sri-hover');
    });
    dropzone.addEventListener('dragleave', () => dropzone.classList.remove('sri-hover'));
    dropzone.addEventListener('drop', async (e: DragEvent) => {
      e.preventDefault();
      const file = e.dataTransfer?.files[0];
      if (file) await handleFile(file);
    });
  }

  function setupPresets(presetBtns: NodeListOf<Element>, zoomRange: HTMLInputElement | null) {
    presetBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const preset = JSON.parse(btn.getAttribute('data-preset')!);
        presetBtns.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        resizer?.setPreset(preset);
        if (zoomRange) zoomRange.value = '100';
      });
    });
  }

  function setupControls(zoomRange: HTMLInputElement | null, resetBtn: HTMLElement | null, downloadBtn: HTMLElement | null) {
    zoomRange?.addEventListener('input', () => {
      resizer?.setScale(parseInt(zoomRange.value) / 100);
    });
    resetBtn?.addEventListener('click', () => {
      const activeBtn = document.querySelector('.sri-preset-btn.active');
      if (activeBtn) {
        resizer?.setPreset(JSON.parse(activeBtn.getAttribute('data-preset')!));
        if (zoomRange) zoomRange.value = '100';
      }
    });
    downloadBtn?.addEventListener('click', () => resizer?.download());
  }

  function init() {
    const dropzone = document.getElementById('sri-dropzone');
    const fileInput = document.getElementById('sri-file-input') as HTMLInputElement | null;
    if (!dropzone || !fileInput) return;
    dropzoneEl = dropzone;
    editorViewEl = document.getElementById('sri-editor-view');
    const presetBtns = document.querySelectorAll('.sri-preset-btn');
    const zoomRange = document.getElementById('sri-zoom-range') as HTMLInputElement | null;
    resizer = new SocialResizer('sri-canvas');
    resizer.zoomRangeEl = zoomRange;
    setupDropzone(dropzone, fileInput);
    setupPresets(presetBtns, zoomRange);
    setupControls(zoomRange, document.getElementById('sri-reset-btn'), document.getElementById('sri-download-btn'));
    resizer.setPreset(JSON.parse(presetBtns[0].getAttribute('data-preset')!));
  }

  document.addEventListener('astro:page-load', init);
  init();
</script>

