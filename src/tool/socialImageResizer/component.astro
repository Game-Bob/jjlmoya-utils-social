---
import type { KnownLocale } from '../../types';
import type { SocialImageResizerUI } from './ui';

interface Props {
  locale?: KnownLocale;
  ui?: Record<string, unknown>;
}

const { ui } = Astro.props;
const t = (ui ?? {}) as SocialImageResizerUI;

const presets = [
  { id: 'ig-square',   name: 'Instagram Square',    size: '1080×1080', width: 1080, height: 1080, iconKey: 'instagram' },
  { id: 'ig-portrait', name: 'Instagram Portrait',  size: '1080×1350', width: 1080, height: 1350, iconKey: 'instagram' },
  { id: 'ig-story',    name: 'Stories / TikTok',    size: '1080×1920', width: 1080, height: 1920, iconKey: 'phone' },
  { id: 'yt-thumb',    name: 'YouTube Thumb',        size: '1280×720',  width: 1280, height: 720,  iconKey: 'youtube' },
  { id: 'yt-banner',   name: 'YouTube Banner',       size: '2560×1440', width: 2560, height: 1440, iconKey: 'youtube' },
  { id: 'x-post',      name: 'X / Twitter Post',     size: '1200×675',  width: 1200, height: 675,  iconKey: 'twitter' },
  { id: 'x-header',    name: 'X / Twitter Header',   size: '1500×500',  width: 1500, height: 500,  iconKey: 'header' },
  { id: 'li-header',   name: 'LinkedIn Cover',        size: '1584×396',  width: 1584, height: 396,  iconKey: 'linkedin' },
];

const icons: Record<string, string> = {
